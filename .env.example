# Copie este arquivo para .env no servidor e preencha apenas o necessario.

# Arquivo TXT exportado do SNMPc dentro da pasta imports.
SNMPC_FILE=imports/SNMPc.txt

# MapTiler e usado para mapa/satelite/geocoding quando configurado.
MAPTILER_API_KEY=
MAPTILER_TOKEN=
MAPTILER_SATELLITE_STYLE_ID=hybrid

# Mapbox fica disponivel apenas como compatibilidade/fallback.
MAPBOX_API_KEY=
